@{
    ViewData["Title"] = "Home";
    var personalInfo = ViewBag.PersonalInfo as Sumit_Portfolio.Models.PersonalInfo;
    var skills = ViewBag.Skills as List<Sumit_Portfolio.Models.Skill>;
    var projects = ViewBag.Projects as List<Sumit_Portfolio.Models.Project>;
}

<!-- Hero Section -->
<section id="home" class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="hero-content">
                    <h1 class="hero-title">Hi, I'm @personalInfo?.Name</h1>
                    <p class="hero-description">@personalInfo?.Summary</p>
                    <div class="hero-buttons">
                        <a href="@Url.Action("Projects", "Home")" class="btn-custom">
                            <i class="fas fa-briefcase me-2"></i>View My Work
                        </a>
                        <a href="@Url.Action("Contact", "Home")" class="btn-outline-custom">
                            <i class="fas fa-envelope me-2"></i>Get In Touch
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-image text-center">
                    <div class="profile-card float-animation">
                        <div class="profile-image-container">
                            <div class="profile-image">
                                <div class="profile-bg">
                                    @if(!string.IsNullOrEmpty(personalInfo?.PhotoUrl))
                                    {
                                        <img src="@personalInfo.PhotoUrl" alt="@personalInfo.Name" class="profile-photo" />
                                    }
                                    else
                                    {
                                        <i class="fas fa-user-tie"></i>
                                    }
                                </div>
                                <div class="profile-ring"></div>
                                <div class="profile-ring-2"></div>
                            </div>
                            <div class="profile-status">
                                <i class="fas fa-circle text-success"></i>
                                <span>Available for work</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Skills Overview -->
<section id="skills" class="section bg-light">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h2 class="section-title">Technical Expertise</h2>
            </div>
        </div>
        <div class="row">
            @if (skills != null)
            {
                @foreach (var skill in skills.Take(6))
                {
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="skill-item text-center">
                            <div class="skill-icon mb-3">
                                @switch (skill.Category.ToLower())
                                {
                                    case "programming":
                                        <i class="fas fa-code" style="font-size: 2rem; color: var(--secondary-color);"></i>
                                        break;
                                    case "framework":
                                        <i class="fas fa-layer-group" style="font-size: 2rem; color: var(--secondary-color);"></i>
                                        break;
                                    case "database":
                                        <i class="fas fa-database" style="font-size: 2rem; color: var(--secondary-color);"></i>
                                        break;
                                    case "frontend":
                                        <i class="fas fa-paint-brush" style="font-size: 2rem; color: var(--secondary-color);"></i>
                                        break;
                                    case "tools":
                                        <i class="fas fa-tools" style="font-size: 2rem; color: var(--secondary-color);"></i>
                                        break;
                                    case "orm":
                                        <i class="fas fa-sitemap" style="font-size: 2rem; color: var(--secondary-color);"></i>
                                        break;
                                    default:
                                        <i class="fas fa-cog" style="font-size: 2rem; color: var(--secondary-color);"></i>
                                        break;
                                }
                            </div>
                            <h5 class="skill-name">@skill.Name</h5>
                            <div class="skill-bar">
                                <div class="skill-progress" data-skill-level="@skill.Level"></div>
                            </div>
                            <small class="skill-level">@skill.Level%</small>
                        </div>
                    </div>
                }
            }
        </div>
        <div class="text-center mt-4">
            <a href="@Url.Action("Skills", "Home")" class="btn-custom">
                <i class="fas fa-eye me-2"></i>View All Skills
            </a>
        </div>
    </div>
</section>

<!-- Featured Projects -->
<section class="section">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h2 class="section-title">Featured Projects</h2>
            </div>
        </div>
        <div class="row">
            @if (projects != null)
            {
                @foreach (var project in projects.Take(3))
                {
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="project-card">
                            <div class="project-image">
                                <div class="project-overlay">
                                    <div class="project-links">
                                        <a href="@project.DemoUrl" target="_blank" data-bs-toggle="tooltip" title="Live Demo">
                                            <i class="fas fa-external-link-alt"></i>
                                        </a>
                                        <a href="@project.GitHubUrl" target="_blank" data-bs-toggle="tooltip" title="Source Code">
                                            <i class="fab fa-github"></i>
                                        </a>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center justify-content-center h-100">
                                    <i class="fas fa-laptop-code" style="font-size: 4rem; color: rgba(255,255,255,0.8);"></i>
                                </div>
                            </div>
                            <div class="project-content">
                                <h5 class="project-title">@project.Title</h5>
                                <p class="project-description">@project.Description</p>
                                <div class="project-tech">
                                    <i class="fas fa-tags me-1"></i>@project.Technologies
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
        <div class="text-center mt-4">
            <a href="@Url.Action("Projects", "Home")" class="btn-custom">
                <i class="fas fa-folder-open me-2"></i>View All Projects
            </a>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section class="section bg-light">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <h2 class="section-title">Let's Work Together</h2>
                <p class="lead mb-4">
                    I'm always interested in new opportunities and exciting projects. 
                    Whether you have a project in mind or just want to chat about technology, 
                    I'd love to hear from you.
                </p>
                <a href="@Url.Action("Contact", "Home")" class="btn-custom btn-lg">
                    <i class="fas fa-paper-plane me-2"></i>Start a Conversation
                </a>
            </div>
        </div>
    </div>
</section>
